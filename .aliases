alias nix-install="nix-env -i"
alias nix-update="nix-env -u '*'"
alias cdx="codex"
alias cdxp="codex --profile"
alias cld="claude"
alias cldp="claude --model opus --effort xhigh"
alias cldd="claude --model sonnet --effort high"
alias nix-install="nix-env -i"
alias nix-update="nix-env -u '*'"
alias hm-dev='nix run github:nix-community/home-manager -- switch --flake ".#dev" -b hm-backup'