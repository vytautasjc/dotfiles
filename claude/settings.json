{
  "model": "sonnet",
  "effortLevel": "high",
  "permissions": {
    "allow": [
      "Bash(pnpm run lint)",
      "Bash(pnpm run type:check)",
      "Bash(pnpm run build)",
      "Bash(pnpm run test:*)",
      "Read(~/.zshrc)",
      "Bash(git diff:*)"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(curl:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ],
    "deny": []
  },
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "OTEL_METRICS_EXPORTER": "otlp"
  },
  "statusLine": {
    "type": "command",
    "command": "${CLAUDE_CONFIG_DIR:-$HOME/.claude}/statusline.sh"
  },
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": ["docker"],
    "network": {
      "allowUnixSockets": [
        "/var/run/docker.sock"
      ],
      "allowLocalBinding": true
    }
  }
}